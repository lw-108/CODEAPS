# CodeAps Desktop — Environment Configuration
# Copy this file to .env and adjust values for your setup

# Python Path
PYTHONPATH=.;..

# Application
ENVIRONMENT=development
PROJECT_NAME=CodeAps Desktop

# Security — CHANGE THIS IN PRODUCTION
SECRET_KEY=codeaps-dev-secret-key-change-in-production-2026
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Database
DATABASE_URL=sqlite:///./codeaps.db
DB_POOL_SIZE=5
DB_POOL_RECYCLE=3600

# Logging
LOG_LEVEL=DEBUG
LOG_DIR=logs

# AI Engine
AI_DEFAULT_MODEL=llama3
AI_DEFAULT_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
